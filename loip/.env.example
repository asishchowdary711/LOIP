# =============================================================================
# LOIP — Environment Configuration
# Copy to .env and fill in real values before running.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=loip
POSTGRES_PASSWORD=changeme
POSTGRES_DB=loip
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# --- OpenSearch ---
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- vLLM / Ollama ---
VLLM_BASE_URL=http://localhost:8000/v1
OLLAMA_BASE_URL=http://localhost:11434

# --- India KYC API Keys (mock stubs used if empty) ---
NSDL_API_KEY=
NSDL_API_URL=https://api.nsdl.example.com/pan/verify
UIDAI_API_KEY=
UIDAI_API_URL=https://api.uidai.example.com/otp/verify
CIBIL_API_KEY=
CIBIL_API_URL=https://api.cibil.example.com/report
EXPERIAN_API_KEY=
EXPERIAN_API_URL=https://api.experian.example.com/report
DIGILOCKER_API_KEY=
DIGILOCKER_API_URL=https://api.digilocker.example.com/fetch

# --- Application Settings ---
APP_ENV=development
APP_SECRET_KEY=changeme-use-openssl-rand-hex-32
LOG_LEVEL=INFO

# --- Data Residency (RBI compliance) ---
DATA_REGION=ap-south-1
ENFORCE_DATA_RESIDENCY=true

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_UPLOAD=10/minute

# --- Consent / DPDP ---
DPDP_CONSENT_VERSION=1.0
